# Copy to .env and adjust. EXPO_PUBLIC_* vars are embedded in the client bundle.

# REST API base (no trailing path segments required by axios for most calls)
EXPO_PUBLIC_API_BASE_URL=https://api.freeapi.app

# Optional — Google AI Studio / Gemini API key for course recommendations
EXPO_PUBLIC_GEMINI_API_KEY=

# Optional — for future real Sentry init (currently stubbed in src/services/sentry.ts)
EXPO_PUBLIC_SENTRY_DSN=
